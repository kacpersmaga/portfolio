---

---

<div
    id="about-me-modal"
    class="fixed inset-0 z-[100] grid place-items-center p-4 bg-black/90 backdrop-blur-md hidden opacity-0 transition-opacity duration-300"
    style="height: 100dvh"
>
    <div
        class="bg-[#121212] border border-dotnet/30 p-6 md:p-10 rounded-3xl max-w-md w-full relative shadow-[0_0_50px_-12px_rgba(81,43,212,0.5)] max-h-[85dvh] overflow-y-auto"
    >
        <button
            id="close-modal"
            class="absolute top-4 right-4 text-gray-500 hover:text-dotnet transition-colors text-2xl font-mono p-2 cursor-pointer"
        >
            &lt;close/&gt;
        </button>

        <div class="flex items-center gap-4 mb-6">
            <div
                class="w-12 h-12 rounded-full border border-dotnet bg-dotnet/10 flex items-center justify-center text-dotnet font-black shadow-[0_0_15px_rgba(81,43,212,0.3)]"
            >
                KS
            </div>
            <h2 class="text-xl font-bold t-primary uppercase tracking-tight">
                Personal Log
            </h2>
        </div>

        <div
            class="space-y-4 text-gray-400 text-sm md:text-base leading-relaxed font-sans"
        >
            <p>
                I'm a 21-year-old developer from Cracow, mainly focused on <strong
                    class="t-primary">.NET</strong
                >. I want to build things that actually matter and make people's
                lives at least a little bit easier through my code.
            </p>
            <p>
                Most recently I completed an internship at <strong class="t-primary"
                    >Futurum Technology</strong
                >, where I worked on a large-scale cross-platform app built with <strong
                    class="t-primary">.NET MAUI</strong
                >. I helped stabilize the app after a migration from Xamarin,
                fixing UI/UX inconsistencies across iOS and Android and working
                through a 200+ bug backlog.
            </p>
            <p>
                When I'm not grinding on a new feature, you'll probably find me
                at the
                <strong class="t-primary">gym</strong>, hitting the <strong
                    class="t-primary">squash</strong
                > court, or just
                <strong class="t-primary">gaming</strong> with the boys. I'm a big
                believer in staying active to keep the brain sharp for the next big
                project.
            </p>
        </div>
    </div>
</div>

<script>
    const trigger = document.getElementById("about-me-trigger");
    const modal = document.getElementById("about-me-modal");
    const close = document.getElementById("close-modal");

    trigger?.addEventListener("click", () => {
        modal?.classList.remove("hidden");
        setTimeout(() => modal?.classList.add("opacity-100"), 10);
        document.body.style.overflow = "hidden";
    });

    const closeModal = () => {
        modal?.classList.remove("opacity-100");
        setTimeout(() => {
            modal?.classList.add("hidden");
            document.body.style.overflow = "auto";
        }, 300);
    };

    close?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
    });
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
    });
</script>
