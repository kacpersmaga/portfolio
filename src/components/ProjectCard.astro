---
import { Image } from "astro:assets";

interface Props {
    title: string;
    description: string;
    image?: any;
    tags: string[];
    githubUrl: string;
    class?: string;
    challenge?: string;
    decisions?: string;
    deepDive?: string;
    lessons?: string;
}

const {
    title,
    description,
    image,
    tags,
    githubUrl,
    class: className,
    challenge,
    decisions,
    deepDive,
    lessons,
} = Astro.props;
---

<div
    class={`project-card group relative overflow-hidden bg-bento-bg border border-bento-border rounded-[2.5rem] p-6 transition-all duration-500 hover:border-dotnet/50 hover:shadow-[0_0_50px_-15px_rgba(81,43,212,0.4)] flex flex-col justify-between cursor-pointer ${className}`}
    data-title={title}
    data-challenge={challenge}
    data-decisions={decisions}
    data-deepdive={deepDive}
    data-lessons={lessons}
    data-tags={tags.join(", ")}
    data-github={githubUrl}
>
    <div class="relative z-10" id="card-content">
        <div class="flex justify-between items-start mb-4">
            <div>
                <h3
                    class="text-3xl font-black text-white italic uppercase tracking-tighter mb-2 leading-none"
                >
                    {title}
                </h3>
                <div class="flex flex-wrap gap-2">
                    {
                        tags.map((tag) => (
                            <span class="text-[9px] px-2 py-0.5 bg-dotnet/10 border border-dotnet/20 text-dotnet rounded-md font-mono uppercase font-bold">
                                {tag}
                            </span>
                        ))
                    }
                </div>
            </div>
            <a
                href={githubUrl}
                target="_blank"
                onclick="event.stopPropagation()"
                class="p-3 bg-white/5 hover:bg-dotnet hover:text-white rounded-2xl text-gray-400 transition-all cursor-pointer"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    ><path
                        d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
                    ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
                >
            </a>
        </div>

        <p class="text-gray-400 text-sm leading-relaxed mb-6">{description}</p>

        {
            image && (
                <div class="relative w-full h-64 md:h-80 overflow-hidden rounded-[1.5rem] border border-white/5 mb-2 shadow-2xl">
                    <Image
                        src={image}
                        alt={title}
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-bento-bg/60 to-transparent" />
                </div>
            )
        }
    </div>

    <button
        class="view-details-btn cursor-pointer mt-4 flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.2em] text-gray-500 hover:text-dotnet transition-colors"
    >
        <span class="w-8 h-px bg-gray-800"></span> View_Engineering_Log
    </button>
</div>
