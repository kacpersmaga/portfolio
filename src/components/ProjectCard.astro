---
import { Image } from "astro:assets";

interface Props {
    title: string;
    description: string;
    image?: any;
    tags: string[];
    githubUrl: string;
    liveUrl?: string;
    class?: string;
    challenge?: string;
    decisions?: string;
    deepDive?: string;
    lessons?: string;
}

const {
    title,
    description,
    image,
    tags,
    githubUrl,
    liveUrl,
    class: className,
    challenge,
    decisions,
    deepDive,
    lessons,
} = Astro.props;

const hasVisualSlot = Astro.slots.has("visual");
---

<div
    class={`project-card group relative overflow-hidden bg-bento-bg border border-bento-border rounded-[2.5rem] p-6 md:p-8 transition-all duration-500 hover:border-dotnet/50 hover:shadow-[0_0_60px_-15px_rgba(81,43,212,0.35)] flex flex-col cursor-pointer ${className}`}
    data-title={title}
    data-challenge={challenge}
    data-decisions={decisions}
    data-deepdive={deepDive}
    data-lessons={lessons}
    data-tags={tags.join(", ")}
    data-github={githubUrl}
    data-liveurl={liveUrl || null}
>
    <!-- Hover gradient overlay -->
    <div
        class="absolute -inset-px bg-gradient-to-br from-dotnet/5 via-transparent to-astro/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-[2.5rem] pointer-events-none"
    >
    </div>

    <div class="relative z-10 flex flex-col h-full">
        <!-- Header: title + tags + github -->
        <div class="flex justify-between items-start mb-4 gap-4">
            <div class="flex-1 min-w-0">
                <h3
                    class="text-3xl font-black t-primary italic uppercase tracking-tighter mb-3 leading-none"
                >
                    {title}
                </h3>
                <div class="flex flex-wrap gap-1.5">
                    {
                        tags.map((tag) => (
                            <span class="text-[9px] px-2.5 py-1 bg-dotnet/10 border border-dotnet/20 text-dotnet rounded-lg font-mono uppercase font-bold tracking-wide">
                                {tag}
                            </span>
                        ))
                    }
                </div>
            </div>
            <a
                href={githubUrl}
                target="_blank"
                onclick="event.stopPropagation()"
                class="shrink-0 p-3 bg-white/5 hover:bg-dotnet hover:text-white rounded-2xl text-gray-400 transition-all cursor-pointer"
                title="View on GitHub"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    ><path
                        d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
                    ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
                >
            </a>
        </div>

        <!-- Description -->
        <p class="text-gray-400 text-sm leading-relaxed mb-5">{description}</p>

        <!-- Visual: image OR slot (e.g. architecture diagram) -->
        {
            image ? (
                <div class="relative w-full h-56 md:h-72 overflow-hidden rounded-[1.5rem] border border-white/5 mb-4 shadow-2xl">
                    <Image
                        src={image}
                        alt={title}
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-bento-bg/70 to-transparent" />
                </div>
            ) : hasVisualSlot ? (
                <slot name="visual" />
            ) : null
        }

        <!-- Footer -->
        <div class="mt-auto pt-4 flex items-center justify-between">
            <button
                class="view-details-btn cursor-pointer flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.2em] text-gray-500 hover:text-dotnet transition-colors"
            >
                <span class="w-8 h-px bg-gray-700 group-hover:bg-dotnet/50 transition-colors"></span>
                View_Engineering_Log
            </button>
            {
                liveUrl && (
                    <span class="text-[9px] font-mono text-astro/70 uppercase tracking-wider">
                        ● Live
                    </span>
                )
            }
        </div>
    </div>
</div>
