---
import Card from "../Card.astro";
import Image from "astro/components/Image.astro";
import myProfileImage from "../../assets/my-profile.jpg";
import AboutMeModal from "../AboutMeModal.astro";
---

<Card
    class="col-span-1 md:col-span-8 md:row-span-3 flex flex-col md:flex-row gap-6 md:gap-8 items-center text-center md:text-left bg-gradient-to-br from-bento-bg to-dotnet/5 relative"
>
    <div
        id="about-me-trigger"
        class="relative group w-32 h-32 md:w-48 md:h-48 rounded-3xl overflow-hidden border-2 border-dotnet/20 shrink-0 shadow-2xl cursor-help mx-auto md:mx-0"
    >
        <Image
            src={myProfileImage}
            alt="Kacper Smaga"
            width={400}
            height={400}
            loading="eager"
            fetchpriority="high"
            sizes="(max-width: 768px) 128px, 192px"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
        <div
            class="absolute inset-0 bg-dotnet/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center"
        >
            <span
                class="t-primary font-mono text-xs font-bold uppercase tracking-tighter bg-black/60 px-3 py-1 rounded-full border border-white/20"
            >
                Check Bio
            </span>
        </div>
    </div>

    <div class="flex flex-col justify-center mt-4 md:mt-0">
        <span
            class="text-dotnet font-mono text-sm mb-2 tracking-tighter uppercase"
        >
            // .NET Developer
        </span>
        <h1
            class="text-3xl lg:text-5xl font-black t-primary mb-4 leading-none uppercase tracking-tight"
        >
            Kacper Smaga <span class="text-dotnet">.</span>
        </h1>
        <p class="text-gray-400 text-base md:text-lg max-w-md leading-relaxed">
            I'm a <strong class="t-primary font-bold">21-year-old</strong> dev
            specializing in <strong class="t-primary font-bold">.NET</strong> systems.
        </p>
    </div>
</Card>

<AboutMeModal />
