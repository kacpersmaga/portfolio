---
import Card from "../Card.astro";
---

<Card
    class="col-span-1 md:col-span-8 md:row-span-3 flex flex-col md:flex-row gap-6 md:gap-8 items-center text-center md:text-left bg-gradient-to-br from-bento-bg to-dotnet/5 relative"
>
    <div
        id="about-me-trigger"
        class="relative group w-32 h-32 md:w-48 md:h-48 rounded-3xl overflow-hidden border-2 border-dotnet/20 shrink-0 shadow-2xl cursor-help mx-auto md:mx-0"
    >
        <img
            src="/twoje-zdjecie.jpg"
            alt="Kacper Smaga"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
        <div
            class="absolute inset-0 bg-dotnet/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center"
        >
            <span
                class="text-white font-mono text-xs font-bold uppercase tracking-tighter bg-black/60 px-3 py-1 rounded-full border border-white/20"
            >
                Check Bio
            </span>
        </div>
    </div>

    <div class="flex flex-col justify-center mt-4 md:mt-0">
        <span
            class="text-dotnet font-mono text-sm mb-2 tracking-tighter uppercase"
        >
            // Full Stack Engineer
        </span>
        <h1
            class="text-3xl lg:text-5xl font-black text-white mb-4 leading-none uppercase tracking-tight"
        >
            Kacper Smaga <span class="text-dotnet">.</span>
        </h1>
        <p class="text-gray-400 text-base md:text-lg max-w-md leading-relaxed">
            I'm a <strong class="text-white font-bold">21-year-old</strong> dev specializing
            in
            <strong class="text-white font-bold">.NET</strong> systems and clean
            <strong class="text-white font-bold">Next.js</strong> interfaces.
        </p>
    </div>
</Card>

<div
    id="about-me-modal"
    class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/90 backdrop-blur-md hidden opacity-0 transition-all duration-300"
>
    <div
        class="bg-[#121212] border border-dotnet/30 p-6 md:p-10 rounded-3xl max-w-md w-full relative shadow-[0_0_50px_-12px_rgba(81,43,212,0.5)]"
    >
        <button
            id="close-modal"
            class="absolute top-4 right-4 text-gray-500 hover:text-white transition-colors text-2xl font-mono p-2"
        >
            &lt;close/&gt;
        </button>

        <div class="flex items-center gap-4 mb-6">
            <div
                class="w-12 h-12 rounded-full border border-dotnet bg-dotnet/10 flex items-center justify-center text-dotnet font-black shadow-[0_0_15px_rgba(81,43,212,0.3)]"
            >
                KS
            </div>
            <h2 class="text-xl font-bold text-white uppercase tracking-tight">
                Personal Log
            </h2>
        </div>

        <div
            class="space-y-4 text-gray-400 text-sm md:text-base leading-relaxed font-sans"
        >
            <p>
                I'm a 21-year-old developer from Cracow, mainly focused on <strong
                    >.NET</strong
                >. I want to build things that actually matter and make people's
                lives at least a little bit easier through my code.
            </p>
            <p>
                When I'm not grinding on a new feature, you'll probably find me
                at the
                <strong>gym</strong>, hitting the <strong>squash</strong> court, or
                just
                <strong>gaming</strong> with the boys. I'm a big believer in staying
                active to keep the brain sharp for the next big project.
            </p>
        </div>
    </div>
</div>

<script>
    const trigger = document.getElementById("about-me-trigger");
    const modal = document.getElementById("about-me-modal");
    const close = document.getElementById("close-modal");

    trigger?.addEventListener("click", () => {
        modal?.classList.remove("hidden");
        setTimeout(() => modal?.classList.add("opacity-100"), 10);
        document.body.style.overflow = "hidden";
    });

    const closeModal = () => {
        modal?.classList.remove("opacity-100");
        setTimeout(() => {
            modal?.classList.add("hidden");
            document.body.style.overflow = "auto";
        }, 300);
    };

    close?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
    });
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
    });
</script>
