---
import Card from "../Card.astro";
---

<Card
    class="col-span-1 md:col-span-4 md:row-span-4 flex flex-col justify-between border-dotnet/10 h-full"
>
    <div>
        <h3 class="text-xl font-bold text-white mb-1">Expertise</h3>
        <p
            class="text-[10px] text-gray-500 uppercase tracking-[0.2em] font-bold"
        >
            Tech Stack
        </p>
    </div>
    <div class="space-y-3 mt-6">
        <div
            class="flex justify-between items-center bg-white/[0.03] p-3 rounded-2xl border border-white/[0.05]"
        >
            <span class="font-bold text-sm">.NET 9 / C#</span>
            <span
                class="text-[9px] px-2 py-1 bg-dotnet/20 text-dotnet rounded-lg font-mono uppercase"
                >Backend</span
            >
        </div>
        <div
            class="flex justify-between items-center bg-white/[0.03] p-3 rounded-2xl border border-white/[0.05]"
        >
            <span class="font-bold text-sm">Next.js / TS</span>
            <span
                class="text-[9px] px-2 py-1 bg-white/10 text-white rounded-lg font-mono uppercase"
                >Frontend</span
            >
        </div>
        <div
            class="flex justify-between items-center bg-white/[0.03] p-3 rounded-2xl border border-white/[0.05]"
        >
            <span class="font-bold text-sm">PostgreSQL</span>
            <span
                class="text-[9px] px-2 py-1 bg-blue-500/20 text-blue-400 rounded-lg font-mono uppercase"
                >Database</span
            >
        </div>
    </div>
    <div class="mt-8 p-4 bg-dotnet/5 rounded-2xl border border-dotnet/10">
        <p
            class="text-[11px] text-gray-400 leading-relaxed font-medium text-center md:text-left"
        >
            <span class="text-dotnet">#</span> Clean Architecture, DDD, Microservices
            & Cloud Native Approach.
        </p>
    </div>
</Card>
