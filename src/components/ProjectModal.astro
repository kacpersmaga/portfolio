---

---

<div
    id="project-modal"
    class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/95 backdrop-blur-md hidden opacity-0 transition-all duration-300"
>
    <div
        class="bg-[#0f0f0f] border border-dotnet/30 rounded-[3rem] max-w-3xl w-full max-h-[90vh] overflow-y-auto relative shadow-[0_0_100px_-20px_rgba(81,43,212,0.3)]"
    >
        <button
            id="close-project-modal"
            class="absolute top-5 right-5 md:top-8 md:right-8 text-gray-500 hover:text-white transition-all z-[110] bg-[#0f0f0f]/80 backdrop-blur-sm p-2 md:px-3 md:py-2 rounded-full border border-white/5 flex items-center justify-center cursor-pointer"
        >
            <span
                class="hidden md:block text-[10px] font-mono uppercase tracking-[0.3em]"
                >[ close_log ]</span
            >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 md:hidden"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <div class="p-8 md:p-12 pt-12 md:pt-16">
            <header class="mb-10 relative">
                <div class="w-full relative mb-4">
                    <div
                        id="modal-tags"
                        class="flex flex-nowrap gap-2 overflow-x-auto no-scrollbar pr-12 md:pr-0 scroll-smooth"
                    >
                    </div>
                    <div
                        class="absolute right-0 top-0 h-full w-12 bg-gradient-to-l from-[#0f0f0f] to-transparent pointer-events-none md:hidden"
                    >
                    </div>
                </div>

                <h2
                    id="modal-title"
                    class="text-4xl md:text-7xl font-black text-white uppercase italic tracking-tighter leading-[0.9] pr-10"
                >
                </h2>

                <a
                    id="modal-github"
                    href="#"
                    target="_blank"
                    class="inline-flex items-center gap-2 mt-6 text-dotnet hover:text-white transition-colors font-mono text-[10px] uppercase tracking-[0.2em] cursor-pointer"
                >
                    view_source_code_on_github ↗
                </a>
            </header>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                <div class="space-y-8">
                    <section>
                        <h4
                            class="text-dotnet font-mono text-[9px] uppercase tracking-[0.3em] mb-3"
                        >
                            // The Challenge
                        </h4>
                        <p
                            id="modal-challenge"
                            class="text-gray-400 text-sm leading-relaxed"
                        >
                        </p>
                    </section>
                    <section>
                        <h4
                            class="text-dotnet font-mono text-[9px] uppercase tracking-[0.3em] mb-3"
                        >
                            // Architectural Decisions
                        </h4>
                        <p
                            id="modal-decisions"
                            class="text-gray-400 text-sm leading-relaxed"
                        >
                        </p>
                    </section>
                </div>
                <div class="space-y-8">
                    <section>
                        <h4
                            class="text-dotnet font-mono text-[9px] uppercase tracking-[0.3em] mb-3"
                        >
                            // Technical Deep Dive
                        </h4>
                        <p
                            id="modal-deepdive"
                            class="text-gray-400 text-sm leading-relaxed italic border-l border-dotnet/30 pl-4"
                        >
                        </p>
                    </section>
                    <section>
                        <h4
                            class="text-dotnet font-mono text-[9px] uppercase tracking-[0.3em] mb-3"
                        >
                            // Lessons Learned
                        </h4>
                        <p
                            id="modal-lessons"
                            class="text-gray-400 text-sm leading-relaxed"
                        >
                        </p>
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    #project-modal .overflow-y-auto::-webkit-scrollbar {
        width: 4px;
    }
    #project-modal .overflow-y-auto::-webkit-scrollbar-track {
        background: transparent;
    }
    #project-modal .overflow-y-auto::-webkit-scrollbar-thumb {
        background: rgba(81, 43, 212, 0.3);
        border-radius: 10px;
    }

    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<script>
    const modal = document.getElementById("project-modal");
    const closeBtn = document.getElementById("close-project-modal");
    const cards = document.querySelectorAll(".project-card");

    const openModal = (card) => {
        const data = card.dataset;

        document.getElementById("modal-title").textContent = data.title;
        document.getElementById("modal-challenge").textContent =
            data.challenge || "No documentation available.";
        document.getElementById("modal-decisions").textContent =
            data.decisions || "No documentation available.";
        document.getElementById("modal-deepdive").textContent =
            data.deepdive || "No documentation available.";
        document.getElementById("modal-lessons").textContent =
            data.lessons || "No documentation available.";
        document.getElementById("modal-github").href = data.github;

        const tagsContainer = document.getElementById("modal-tags");
        tagsContainer.scrollLeft = 0;

        tagsContainer.innerHTML = data.tags
            ? data.tags
                  .split(",")
                  .map(
                      (tag) =>
                          `<span class="flex-shrink-0 text-[9px] px-3 py-1 bg-dotnet/10 text-dotnet border border-dotnet/20 rounded-md font-mono uppercase font-bold whitespace-nowrap cursor-default">${tag.trim()}</span>`,
                  )
                  .join("")
            : "";

        modal.classList.remove("hidden");
        setTimeout(() => modal.classList.add("opacity-100"), 10);
        document.body.style.overflow = "hidden";
    };

    const closeModal = () => {
        modal.classList.remove("opacity-100");
        setTimeout(() => {
            modal.classList.add("hidden");
            document.body.style.overflow = "auto";
        }, 300);
    };

    cards.forEach((card) => {
        card.addEventListener("click", () => openModal(card));
    });

    closeBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
    });
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
    });
</script>
