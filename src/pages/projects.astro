---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";

import imgEshop from "../assets/eshop-preview.jpg";
import "../styles/global.css";
import ProjectModal from "../components/ProjectModal.astro";

const projects = [
    {
        title: "eShop Modular",
        description:
            "Advanced modular e-commerce system built with Clean Architecture. Focused on scalability and module independence.",
        image: imgEshop,
        tags: ["CQRS", "DDD", "PostgreSQL", "SignalR"],
        githubUrl: "https://github.com/kacpersmaga",
        challenge:
            "Avoiding the 'Big Ball of Mud' by implementing strict boundaries between business modules in a single repository.",
        decisions:
            "I chose a Modular Monolith over Microservices to reduce infrastructure complexity while keeping the code ready for future split.",
        deepDive:
            "Implemented an Outbox Pattern for reliable domain event dispatching between modules using EF Core and Background Services.",
        lessons:
            "Learned that proper aggregate design is the hardest but most crucial part of DDD.",
    },
    {
        title: "Auth Service",
        description:
            "Identity Server integration with custom JWT flow and OAuth2. Complete security layer for microservices.",
        tags: ["OAuth2", "Identity", "JWT"],
        githubUrl: "https://github.com/kacpersmaga",
        challenge:
            "Creating a secure, centralized authentication point that supports different client types (SPA, Mobile, Machine).",
        decisions:
            "Used ASP.NET Core Identity with OpenIddict to have full control over the token generation process.",
        deepDive:
            "Customized JWT claims transformation to include fine-grained permissions based on user roles and organization context.",
        lessons:
            "Security is not only about code, but also about proper protocol flow and secret management.",
    },
    {
        title: "Clean Template",
        description:
            "Personal starter template for .NET projects with pre-configured MediatR and FluentValidation.",
        tags: ["MediatR", "xUnit", "FluentVal"],
        githubUrl: "https://github.com/kacpersmaga",
        challenge:
            "Setting up a new project always felt repetitive, so I automated the boilerplate.",
        decisions:
            "Included a Result Pattern to avoid throwing exceptions for business logic errors.",
        deepDive:
            "Built-in Global Exception Handler that maps different error types to proper RFC 7807 Problem Details.",
        lessons:
            "A good template is one that is minimal enough to be flexible, but strict enough to maintain order.",
    },
    {
        title: "Traffic Monitor",
        description:
            "Real-time analytics processingmassive data streams using SignalR and Azure Functions.",
        tags: ["SignalR", "Azure", "Redis"],
        githubUrl: "https://github.com/kacpersmaga",
        challenge:
            "Visualizing real-time data spikes without refreshing the page or overloading the client.",
        decisions:
            "Used Redis Backplane for SignalR to allow horizontal scaling across multiple server instances.",
        deepDive:
            "Implemented a throttling mechanism in Azure Functions to batch updates before sending them to the Hub.",
        lessons:
            "Websockets are powerful but require careful management of connection lifecycles.",
    },
    {
        title: "Event Bus",
        description:
            "Lightweight event bus implementation over RabbitMQ for inter-module communication.",
        tags: ["RabbitMQ", "Events", "C#"],
        githubUrl: "https://github.com/kacpersmaga",
        challenge:
            "Ensuring that messages are not lost when a consumer service is temporarily down.",
        decisions:
            "Implemented Dead Letter Exchanges (DLX) to handle failed message processing and retries.",
        deepDive:
            "Used Polly for exponential backoff and circuit breaker patterns during message consumption.",
        lessons:
            "Distributed systems fail in unpredictable ways; always design for failure.",
    },
];

const getGridClass = (index: number) => {
    const pattern = index % 5;
    if (pattern === 0) return "md:col-span-8 md:row-span-2 cursor-pointer";
    if (pattern === 1) return "md:col-span-4 cursor-pointer";
    if (pattern === 2) return "md:col-span-4 cursor-pointer";
    if (pattern === 3) return "md:col-span-6 cursor-pointer";
    if (pattern === 4) return "md:col-span-6 cursor-pointer";
    return "";
};
---

<Layout title="Kacper Smaga | Engineering Lab">
    <main
        class="min-h-screen w-full bg-bento-bg p-4 md:p-12 flex flex-col items-center"
    >
        <div class="w-full max-w-[1200px]">
            <header class="mb-20">
                <a
                    href="/"
                    class="text-dotnet font-mono text-[10px] uppercase tracking-[0.3em] hover:text-white transition-all cursor-pointer"
                >
                    // back_to_grid
                </a>
                <h1
                    class="text-6xl md:text-8xl font-black text-white mt-6 italic uppercase tracking-tighter leading-none"
                >
                    Eng. <span class="text-dotnet text-stroke">Lab</span>
                </h1>
                <p
                    class="text-gray-500 mt-4 max-w-xl uppercase font-bold tracking-[0.2em] text-[10px]"
                >
                    // Technical documentation of my architectural journey
                </p>
            </header>

            <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                {
                    projects.map((project, index) => (
                        <ProjectCard {...project} class={getGridClass(index)} />
                    ))
                }
            </div>
        </div>
    </main>

    <ProjectModal />
</Layout>

<style>
    .text-stroke {
        -webkit-text-stroke: 1px rgb(81, 43, 212);
        color: transparent;
    }
</style>
