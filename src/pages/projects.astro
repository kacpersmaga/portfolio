---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import TicketFlowDiagram from "../components/TicketFlowDiagram.astro";
import EShopDiagram from "../components/eShopDiagram.astro";

import "../styles/global.css";
import ProjectModal from "../components/ProjectModal.astro";

const eshop = {
    title: "eShop",
    description:
        "Full-featured e-commerce platform built with .NET 9 and Clean Architecture. Implements DDD, CQRS with MediatR, containerized with Docker, Redis caching, and Azure Blob Storage for product photos.",
    tags: [".NET 9", "Clean Arch", "DDD", "CQRS", "Docker", "Redis", "EF Core"],
    githubUrl: "https://github.com/kacpersmaga/eShop",
    challenge:
        "Building a modular monolith that enforces strict business module boundaries while remaining deployable as a single unit — then integrating a real frontend and deploying to a VPS.",
    decisions:
        "Chose modular monolith over microservices to keep infrastructure manageable. MediatR for CQRS, Redis for caching, Azure Blob Storage for product images, and Caddy as the reverse proxy for HTTPS.",
    deepDive:
        "FluentValidation on all command boundaries, Serilog for structured logging, automatic MSSQL migrations via EF Core 9. React/Next.js frontend with Framer Motion animations and Axios. CI/CD via GitHub Actions.",
    lessons:
        "Deploying a full-stack app to a real VPS showed me how different production environments are from local dev. Setting up HTTPS, CORS, and Docker networking properly took longer than writing any feature.",
};

const ticketflow = {
    title: "TicketFlow",
    description:
        "Concert ticket ordering system built to learn microservices, gRPC, GraphQL, and async messaging. Five independently deployable services orchestrated with .NET Aspire — no Docker Compose needed.",
    tags: [
        "Microservices",
        ".NET Aspire",
        "gRPC",
        "GraphQL",
        "RabbitMQ",
        "MassTransit",
        "JWT",
    ],
    githubUrl: "https://github.com/kacpersmaga/TicketFlow",
    challenge:
        "Coordinating five independent services — Gateway (GraphQL), Catalog (gRPC + Redis), Identity (JWT), Ordering (REST), and Notifications (worker) — while keeping each one loosely coupled and independently testable.",
    decisions:
        ".NET Aspire for type-safe orchestration and built-in service discovery. HotChocolate for the GraphQL gateway, MassTransit + RabbitMQ for async event publishing, gRPC for synchronous internal calls.",
    deepDive:
        "JWT with single-use refresh token rotation in Identity. Redis-backed catalog caching (30s TTL). Full integration test suite using Aspire test host that boots the entire distributed system per test session. OpenTelemetry with OTLP exporter for distributed tracing across all five services.",
    lessons:
        "Distributed systems fail in unexpected ways. Having OpenTelemetry and the Aspire dashboard from day one made debugging cross-service issues dramatically faster than reading logs.",
};

const otherProjects = [
    {
        title: "NegotiationApp",
        description:
            "A .NET 9 REST API for product price negotiation. Customers propose prices; employees accept or reject — enforced by a clean domain state machine.",
        tags: [".NET 9", "MediatR", "JWT", "MSSQL", "xUnit"],
        githubUrl: "https://github.com/kacpersmaga/ProductNegotiationApp",
        challenge:
            "Modeling the negotiation lifecycle as a clean state machine so invalid transitions are impossible at the domain level, not guarded by controller conditionals.",
        decisions:
            "MediatR for CQRS and pipeline behaviors for cross-cutting concerns. Result Pattern instead of exception-driven flow. FluentValidation on all command boundaries.",
        deepDive:
            "Domain model enforces: max 3 negotiation attempts per product, proposed price must be lower than current. JWT for stateless auth. Serilog for structured logging throughout.",
        lessons:
            "Keeping controllers thin and pushing logic into the domain paid off immediately — changing a business rule meant editing one domain method, not hunting through conditionals.",
    },
    {
        title: "SWIFT Codes API",
        description:
            "FastAPI application that parses and serves SWIFT/BIC bank codes. Built with Python, PostgreSQL, full pytest coverage, and CI/CD via GitHub Actions.",
        tags: ["FastAPI", "Python", "PostgreSQL", "pytest", "Docker"],
        githubUrl: "https://github.com/kacpersmaga/swift-codes-api",
        challenge:
            "Efficiently parsing a large SWIFT code dataset from raw CSV into a queryable PostgreSQL structure with idempotent seeding on container restart.",
        decisions:
            "FastAPI for automatic OpenAPI schema generation and async support. SQLAlchemy + Pydantic for typed data access. GitHub Actions for automated testing and Codecov for coverage.",
        deepDive:
            "Bulk import pipeline validates, deduplicates, and upserts SWIFT records in batches. Pytest fixtures handle test database isolation. Integration tests run against a live PostgreSQL container in CI.",
        lessons:
            "Even a focused CRUD API teaches you that idempotent data seeding, proper CI, and test coverage are non-negotiable habits — not optional polish.",
    },
    {
        title: "Scrabble UI",
        description:
            "Scrabble board interface built with Next.js 15 and TypeScript. Firebase handles user authentication and game history persistence in Firestore. Deployed on Vercel.",
        tags: ["Next.js 15", "Firebase", "TypeScript", "Tailwind", "Firestore"],
        githubUrl: "https://github.com/kacpersmaga/scrabbleGame",
        liveUrl: "https://scrabble-game-nine.vercel.app/",
        challenge:
            "Wiring a 15×15 interactive board with Firebase Firestore for persistent game history and real-time auth state across sessions.",
        decisions:
            "Firebase Authentication for user registration with email verification and password reset. Firestore for saving game sessions per user. Next.js App Router with protected routes.",
        deepDive:
            "Implemented user profiles with editable nicknames and profile pictures. Game history viewable per authenticated user. Playwright used for E2E testing the auth and navigation flows.",
        lessons:
            "Firebase Auth and Firestore integration is straightforward but requires careful security rules — open Firestore rules in dev will silently allow anything, which can bite you in production.",
    },
];
---

<Layout title="Kacper Smaga | Projects">
    <main class="min-h-screen w-full p-4 md:p-12 flex flex-col items-center">
        <div class="w-full max-w-[1200px]">
            <header class="mb-16">
                <a
                    href="/"
                    class="inline-flex items-center gap-2 text-dotnet font-mono text-[10px] uppercase tracking-[0.3em] hover:text-white transition-all cursor-pointer group"
                >
                    <svg
                        class="w-3 h-3 transition-transform group-hover:-translate-x-1"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="3"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 19l-7-7 7-7"></path>
                    </svg>
                    back_to_grid
                </a>
                <h1
                    class="text-6xl md:text-8xl font-black t-primary mt-6 italic uppercase tracking-tighter leading-none"
                >
                    Eng. <span class="text-dotnet text-stroke">Lab</span>
                </h1>
                <p
                    class="text-gray-500 mt-4 max-w-xl uppercase font-bold tracking-[0.2em] text-[10px]"
                >
                    // Technical documentation of my architectural journey
                </p>
            </header>

            <!-- Featured projects: eShop + TicketFlow side by side -->
            <div class="mb-5">
                <p
                    class="text-[9px] font-mono text-dotnet uppercase tracking-[0.3em] mb-4"
                >
                    // featured_projects
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <ProjectCard {...eshop} class="cursor-pointer h-full">
                        <EShopDiagram slot="visual" />
                    </ProjectCard>
                    <ProjectCard {...ticketflow} class="cursor-pointer h-full">
                        <TicketFlowDiagram slot="visual" />
                    </ProjectCard>
                </div>
            </div>

            <!-- Other projects -->
            <div class="mt-5">
                <p
                    class="text-[9px] font-mono text-gray-600 uppercase tracking-[0.3em] mb-4"
                >
                    // other_projects
                </p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                    {
                        otherProjects.map((project) => (
                            <ProjectCard {...project} class="cursor-pointer" />
                        ))
                    }
                </div>
            </div>
        </div>
    </main>

    <ProjectModal />
</Layout>

<style>
    .text-stroke {
        -webkit-text-stroke: 1px rgb(81, 43, 212);
        color: transparent;
    }
</style>
